APP_NAME="LMS MOE"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://lms-moe.weststar-dev.com

APP_LOCALE=ms
APP_FALLBACK_LOCALE=ms
APP_FAKER_LOCALE=ms_MY

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@lms-moe.weststar-dev.com"
MAIL_FROM_NAME="LMS MOE"

TEACHER_REG_CODE=
VIDEO_MAX_MB=100
MATERIAL_MAX_MB=30
QUIZ_FILE_MAX_MB=30

# --- Split-deployment uploads fix (see docs/DEPLOYMENT.md) ---
# The uploads disk must write to the served docroot folder, not app/public.
UPLOADS_ROOT=

# The served docroot (index.php calls usePublicPath on it). deploy.sh syncs
# public/build here on each deploy so the live site never serves stale assets.
# Leave blank on non-split hosts. Example:
#   PUBLIC_DOCROOT=/home3/weststar/public_html/lms-moe.weststar-dev.com
PUBLIC_DOCROOT=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_API_KEY=
GOOGLE_REDIRECT_URI=https://lms-moe.weststar-dev.com/oauth/youtube/callback

# --- Auto-deploy webhook ---
# Generate on the server with:  openssl rand -hex 24
# Set the value ONLY in the server's real .env, never here and never in git.
# Leave blank in this example; public/deploy.php returns 503 while it is unset.
DEPLOY_TOKEN=
