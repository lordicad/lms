# Teacher uploads never enter the repo. The folder scaffolding and the
# no-execute rule do.
/public/uploads/*
!/public/uploads/.htaccess
!/public/uploads/*/
/public/uploads/*/*
!/public/uploads/*/.gitkeep

# Deploy secrets and owner-supplied inputs.
/Filezilla_creds.md
/taste-skill-main.zip
/deploy/deploy.log

# Artisan tinker --execute temp files
__run_*.php

# Laravel runtime artifacts (compiled views, framework cache, sessions)
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep
