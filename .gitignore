*.log
.DS_Store
# Ignore every .env variant and make the template the one exception: the list this
# replaces named four by hand and still let .env.production.bak through, and this
# repo is public.
.env*
!.env.example
.phpactor.json
.phpunit.result.cache
/.fleet
/.idea
/.nova
/.phpunit.cache
/.vscode
/.zed
/auth.json
/node_modules
# /public/build is committed on purpose: the host has no Node to run `vite build`.
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
Homestead.json
Homestead.yaml
Thumbs.db

# Teacher uploads never enter the repo. The folder scaffolding and the
# no-execute rule do.
/public/uploads/*
!/public/uploads/.htaccess
!/public/uploads/*/
/public/uploads/*/*
!/public/uploads/*/.gitkeep

# Deploy secrets and owner-supplied inputs.
# `.env*` above does not cover these: it only matches names that START with .env.
/.deploy.env
/autodeploy.md
/Filezilla_creds.md
/taste-skill-main.zip
/deploy/deploy.log
# Generated dummy-account credential list. Never commit — this repo is public.
/dummy-credentials.csv
/gencreds_tmp.php

# Artisan tinker --execute temp files
__run_*.php

# Laravel runtime artifacts (compiled views, framework cache, sessions)
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitkeep
/storage/framework/sessions/*
!/storage/framework/sessions/.gitkeep
/storage/framework/views/*
!/storage/framework/views/.gitkeep
